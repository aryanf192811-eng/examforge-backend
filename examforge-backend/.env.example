# ══════════════════════════════════════════════════════════════════════
# ExamForge Backend — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════

# ── General ──────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:5173"]

# ── Firebase ─────────────────────────────────────────────────────────
# Option 1: Path to local service account JSON file (for development)
FIREBASE_CREDENTIALS_JSON=./firebase-key.json
# Option 2: Base64-encoded JSON (for deployment — preferred)
# FIREBASE_CREDENTIALS_B64=

# ── Supabase ─────────────────────────────────────────────────────────
