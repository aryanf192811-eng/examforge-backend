# --- Monorepo .gitignore ---

# Environment Secrets
.env
.env.*
!.env.example
*.env

# Dependencies
frontend/
node_modules/
venv/
env/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Build Outputs
dist/
build/
*.egg-info/
.vercel/

# Database
# Note: DO NOT ignore content.db as it's required for deployment
*.db-shm
*.db-wal
# *.db (Uncomment if you want to ignore all local DBs, but keep content.db included)

# IDEs and OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pip-log.txt
pip_err*.txt
pip_out.txt
verify_*_output.txt
